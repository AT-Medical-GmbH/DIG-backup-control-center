[Unit]
Description=ATMED-BCC backup orchestration
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/atmed-bcc
ExecStart=/opt/atmed-bcc/scripts/atmed-bcc-run-backup --config-dir /etc/atmed-bcc
User=atmed-bcc
Group=atmed-bcc
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/atmed-bcc /var/log/atmed-bcc

[Install]
WantedBy=multi-user.target
